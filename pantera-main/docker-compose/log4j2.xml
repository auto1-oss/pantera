<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN" monitorInterval="30">
    <Properties>
        <!-- Service metadata -->
        <Property name="service.name">pantera</Property>
        <Property name="service.version">${env:PANTERA_VERSION:-${project.version}}</Property>
        <Property name="service.environment">${env:PANTERA_ENV:-development}</Property>
    </Properties>

    <Appenders>
        <!-- Console appender with ECS JSON format -->
        <Console name="Console" target="SYSTEM_OUT">
            <EcsLayout serviceName="${service.name}"
                       serviceVersion="${service.version}"
                       serviceEnvironment="${service.environment}"/>
        </Console>

        <!-- Async wrapper: non-blocking, large queue, no location capture -->
        <!-- includeLocation=false: eliminates Throwable allocations per log event -->
        <!-- blocking=false: drops events rather than stalling JVM threads on queue overflow -->
        <!-- bufferSize=4096: survives GC pauses up to ~580ms at 7000 events/s -->
        <!-- Discard policy: set -Dlog4j2.asyncQueueFullPolicy=Discard -Dlog4j2.discardThreshold=info -->
        <Async name="AsyncConsole" bufferSize="4096" blocking="false" includeLocation="false">
            <AppenderRef ref="Console"/>
        </Async>
    </Appenders>

    <Loggers>
        <!-- HTTP Access Logs (ECS-compliant) -->
        <Logger name="http.access" level="info" additivity="false">
            <AppenderRef ref="AsyncConsole"/>
        </Logger>

        <!-- Artifact Audit Logs (upload/download/delete/resolution) -->
        <Logger name="artifact.audit" level="info" additivity="false">
            <AppenderRef ref="AsyncConsole"/>
        </Logger>

        <!-- Pantera application logs -->
        <Logger name="com.auto1.pantera" level="info" additivity="false">
            <AppenderRef ref="AsyncConsole"/>
        </Logger>

        <!-- Pantera auth logs -->
        <Logger name="com.auto1.pantera.auth" level="info" additivity="false">
            <AppenderRef ref="AsyncConsole"/>
        </Logger>

        <!-- Repository adapters - info level for production -->
        <Logger name="com.auto1.pantera.maven" level="info" additivity="false">
            <AppenderRef ref="AsyncConsole"/>
        </Logger>
        <Logger name="com.auto1.pantera.npm" level="info" additivity="false">
            <AppenderRef ref="AsyncConsole"/>
        </Logger>
        <Logger name="com.auto1.pantera.docker" level="info" additivity="false">
            <AppenderRef ref="AsyncConsole"/>
        </Logger>
        <Logger name="com.auto1.pantera.pypi" level="info" additivity="false">
            <AppenderRef ref="AsyncConsole"/>
        </Logger>

        <!-- Third-party libraries (quieter) -->
        <Logger name="io.vertx" level="warn" additivity="false">
            <AppenderRef ref="AsyncConsole"/>
        </Logger>
        <Logger name="org.eclipse.jetty" level="warn" additivity="false">
            <AppenderRef ref="AsyncConsole"/>
        </Logger>
        <Logger name="software.amazon.awssdk" level="warn" additivity="false">
            <AppenderRef ref="AsyncConsole"/>
        </Logger>
        <Logger name="io.netty" level="warn" additivity="false">
            <AppenderRef ref="AsyncConsole"/>
        </Logger>

        <!-- Root logger -->
        <Root level="info">
            <AppenderRef ref="AsyncConsole"/>
        </Root>
    </Loggers>
</Configuration>
