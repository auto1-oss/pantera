# Elastic APM Configuration for Artipie
# Copy this file to your deployment environment and adjust values

# Enable APM
ELASTIC_APM_ENABLED=true

# APM Server Configuration
ELASTIC_APM_SERVER_URL=http://localhost:8200
ELASTIC_APM_SERVICE_NAME=artipie
ELASTIC_APM_ENVIRONMENT=production

# Authentication (use one of these)
# ELASTIC_APM_SECRET_TOKEN=your_secret_token_here
# ELASTIC_APM_API_KEY=your_api_key_here

# Performance Settings
ELASTIC_APM_TRANSACTION_SAMPLE_RATE=1.0
ELASTIC_APM_TRANSACTION_MAX_SPANS=2000
ELASTIC_APM_SPAN_COMPRESSION_ENABLED=true
ELASTIC_APM_SPAN_COMPRESSION_EXACT_MATCH_MAX_DURATION=50ms
ELASTIC_APM_SPAN_COMPRESSION_SAME_KIND_MAX_DURATION=0ms

# Capture Settings
ELASTIC_APM_CAPTURE_BODY=errors
ELASTIC_APM_CAPTURE_HEADERS=true
ELASTIC_APM_LOG_LEVEL=INFO

# SSL Settings (for production)
ELASTIC_APM_VERIFY_SERVER_CERT=true

# Application Packages to Monitor
ELASTIC_APM_APPLICATION_PACKAGES=com.artipie

# Distributed Tracing
ELASTIC_APM_ENABLE_LOG_CORRELATION=true
ELASTIC_APM_TRACE_METHODS=com.artipie.*

# Stack Trace Settings
ELASTIC_APM_STACK_TRACE_LIMIT=50
ELASTIC_APM_SPAN_FRAMES_MIN_DURATION=5ms