# Enterprise supply-chain hardening for pantera-ui.
#
# save-exact: any `npm install <pkg>` writes an exact version to
#   package.json instead of a caret range. This closes the window
#   where a caret range silently resolves to a compromised patch
#   version published during an attacker-controlled window
#   (see: axios 1.14.1 / 0.30.4, March 2026, WAVESHAPER.V2).
#
# package-lock: always write the lockfile. It pins every dep,
#   including transitives, by URL and integrity hash.
#
# engine-strict: fail loudly if the local Node version does not
#   match the engines field, instead of proceeding with an
#   untested runtime.
#
# fund / audit noise is suppressed in CI output but still surfaces
#   in `npm audit` on demand.
#
# Always use `npm ci` (not `npm install`) in build pipelines: it
#   refuses to mutate the lockfile and errors out on any drift.
save-exact=true
package-lock=true
engine-strict=true
fund=false
