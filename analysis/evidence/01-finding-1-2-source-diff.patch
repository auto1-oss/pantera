+    public boolean prefetchEnabled() {
+        final Optional<YamlMapping> cfg = this.settings();
+        if (cfg.isPresent()) {
+            final String explicit = cfg.get().string("prefetch");
+            if (explicit != null && !explicit.isBlank()) {
+                return Boolean.parseBoolean(explicit);
+            }
+        }
+        return false;
+    }
