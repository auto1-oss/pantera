<?xml version="1.0" encoding="UTF-8"?>
<!--
  Minimal Log4j2 configuration for unit tests in pantera-core.
  Sets root level to DEBUG so EcsSchemaValidationTest can capture
  WARN-level events (4xx responses) and DEBUG-level events (2xx responses).
-->
<Configuration status="WARN">
    <Appenders>
        <Console name="TestConsole" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{HH:mm:ss.SSS} [%t] %-5level %logger - %msg%n"/>
        </Console>
    </Appenders>
    <Loggers>
        <Root level="debug">
            <AppenderRef ref="TestConsole"/>
        </Root>
    </Loggers>
</Configuration>
