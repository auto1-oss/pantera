<?xml version="1.0"?>
<ruleset name="pantera-curated"
         xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0 https://pmd.sourceforge.io/ruleset_2_0_0.xsd">
    <description>
        Pantera curated PMD 7 ruleset (Phase 14).
        Focused on rules that catch real bugs:
          - errorprone: comparison/null/thread/state-machine bugs
          - security:  hardcoded creds, weak crypto, path traversal
          - bestpractices: modern-Java API mis-use, resource leaks
          - codestyle: only the ones that hide real bugs
          - design: real architecture issues; LOC-counting rules dropped
          - performance: real perf issues, not micro-optimizations
          - multithreading: real concurrency bugs
        Noise rules (AvoidDuplicateLiterals, OnlyOneReturn, complexity-by-LOC,
        naming-pedantry) are explicitly excluded — the prior 159
        AvoidDuplicateLiterals suppressions alone showed the rule was a
        wholesale-suppression magnet.
    </description>

    <!-- ===== ERROR-PRONE: real bugs ===== -->
    <rule ref="category/java/errorprone.xml">
        <!-- noise: literals duplicated across e.g. logger names, paths, MIME types -->
        <exclude name="AvoidDuplicateLiterals"/>
        <!-- noise: legitimate pattern (e.g. constants like 200/404 in HTTP routing) -->
        <exclude name="AvoidLiteralsInIfCondition"/>
        <!-- noise: serialVersionUID is largely cargo-cult for non-RMI code -->
        <exclude name="MissingSerialVersionUID"/>
        <!-- noise: legitimate accessor/Lombok-style pattern -->
        <exclude name="AvoidFieldNameMatchingMethodName"/>
        <exclude name="AvoidFieldNameMatchingTypeName"/>
    </rule>

    <!-- ===== SECURITY: weak crypto, hardcoded creds, etc. ===== -->
    <rule ref="category/java/security.xml"/>

    <!-- ===== BEST PRACTICES: modern Java, correct API use ===== -->
    <rule ref="category/java/bestpractices.xml">
        <!-- noise: false positives on @Test reflective invocation, lambda-only callers -->
        <exclude name="UnusedPrivateMethod"/>
        <!-- legit: constants on interfaces are a known idiom in this codebase -->
        <exclude name="ConstantsInInterface"/>
        <!-- noise: legacy log4j-style guard, replaced by SLF4J parameterized logging -->
        <exclude name="GuardLogStatement"/>
        <!-- legit: parameterized tests / contract tests don't always have @Test -->
        <exclude name="JUnitTestsShouldIncludeAssert"/>
    </rule>

    <!-- ===== CODE STYLE: only the ones that hide real bugs ===== -->
    <rule ref="category/java/codestyle.xml">
        <!-- noise: multiple returns are fine; bad rule -->
        <exclude name="OnlyOneReturn"/>
        <!-- style only: variable name length not a bug indicator -->
        <exclude name="LongVariable"/>
        <exclude name="ShortVariable"/>
        <exclude name="ShortMethodName"/>
        <exclude name="ShortClassName"/>
        <!-- noise: enforces a constructor on every class incl. utility -->
        <exclude name="AtLeastOneConstructor"/>
        <!-- noise: requires `final` on every parameter/local; opinionated -->
        <exclude name="MethodArgumentCouldBeFinal"/>
        <exclude name="LocalVariableCouldBeFinal"/>
        <!-- noise: legitimate idiom -->
        <exclude name="ConfusingTernary"/>
        <!-- noise: super() is implicit; flagging absent calls is cosmetic -->
        <exclude name="CallSuperInConstructor"/>
        <!-- noise: snake_case test method names hit this regularly -->
        <exclude name="MethodNamingConventions"/>
        <!-- noise: opinionated, often wrong -->
        <exclude name="LinguisticNaming"/>
        <!-- noise: package-private comments are useless ceremony -->
        <exclude name="CommentDefaultAccessModifier"/>
        <!-- noise: requires explicit constructor on all classes -->
        <exclude name="UnnecessaryConstructor"/>
        <!-- noise: micro-cosmetic -->
        <exclude name="UselessParentheses"/>
        <exclude name="UnnecessaryFullyQualifiedName"/>
        <exclude name="UnnecessaryAnnotationValueElement"/>
        <exclude name="UnnecessaryImport"/>
        <!-- noise: opinionated about local-var declaration position -->
        <exclude name="PrematureDeclaration"/>
        <!-- noise: empty bodies are sometimes intentional -->
        <exclude name="EmptyControlStatement"/>
        <!-- legit: var declared but assigned later is fine -->
        <exclude name="UnnecessaryLocalBeforeReturn"/>
    </rule>

    <!-- ===== DESIGN: real architecture issues ===== -->
    <rule ref="category/java/design.xml">
        <!-- noise: frequently-wrong demand for getter-chain refactor -->
        <exclude name="LawOfDemeter"/>
        <!-- noise: package coupling heuristic, often wrong -->
        <exclude name="LoosePackageCoupling"/>
        <!-- noise: judgment-call class-shape rules -->
        <exclude name="DataClass"/>
        <exclude name="GodClass"/>
        <!-- noise: LOC-counting rules; the kind of rule that gets suppressed wholesale -->
        <exclude name="TooManyMethods"/>
        <exclude name="TooManyFields"/>
        <exclude name="ExcessiveImports"/>
        <exclude name="ExcessivePublicCount"/>
        <exclude name="ExcessiveParameterList"/>
        <exclude name="CyclomaticComplexity"/>
        <exclude name="CognitiveComplexity"/>
        <exclude name="NPathComplexity"/>
        <exclude name="NcssCount"/>
        <!-- noise: forces UtilityClass pattern, often wrong -->
        <exclude name="UseUtilityClass"/>
        <!-- judgment: nested-if depth is sometimes natural -->
        <exclude name="AvoidDeeplyNestedIfStmts"/>
        <!-- legit in Optional.orElseThrow patterns and similar -->
        <exclude name="AvoidThrowingNullPointerException"/>
        <!-- noise: sometimes unavoidable when wrapping checked exns -->
        <exclude name="AvoidThrowingRawExceptionTypes"/>
        <exclude name="SignatureDeclareThrowsException"/>
        <!-- noise: false positives on registries/caches/ATOMIC singletons -->
        <exclude name="MutableStaticState"/>
        <!-- noise: legitimate in tests / generic Throwable boundaries -->
        <exclude name="AvoidCatchingGenericException"/>
        <!-- judgment-call: can be a bug, but fires too widely -->
        <exclude name="UseObjectForClearerAPI"/>
    </rule>

    <!-- ===== PERFORMANCE: real perf issues, not micro-opts ===== -->
    <rule ref="category/java/performance.xml">
        <!-- noise: opinionated, sometimes the only correct pattern -->
        <exclude name="AvoidInstantiatingObjectsInLoops"/>
        <!-- legit: + concatenation is fine in modern JIT -->
        <exclude name="UseStringBufferForStringAppends"/>
        <exclude name="ConsecutiveLiteralAppends"/>
        <exclude name="InefficientEmptyStringCheck"/>
        <exclude name="StringInstantiation"/>
    </rule>

    <!-- ===== MULTITHREADING: real concurrency bugs ===== -->
    <rule ref="category/java/multithreading.xml">
        <!-- noise: ConcurrentHashMap not always the right choice -->
        <exclude name="UseConcurrentHashMap"/>
        <!-- legit: Vert.x worker pools and JDK Thread are legitimate -->
        <exclude name="DoNotUseThreads"/>
        <!-- legit: volatile is used correctly throughout for visibility -->
        <exclude name="AvoidUsingVolatile"/>
    </rule>

    <!-- ===== Custom XPath rules from previous ruleset =====
         All custom XPath rules from the PMD 6 ruleset have been DROPPED.
         PMD 7's new AST renders the old XPath expressions invalid:
           OnlyOneConstructorShouldDoInitialization — judgment, too noisy
           ConstructorOnlyInitializesOrCallOtherConstructors — low value
           AvoidDirectAccessToStaticFields — false positives on Builder.X access
           ProhibitPublicStaticMethods — questionable rule (factory methods, parse methods)
           ProhibitFilesCreateFileInTests — only 2 historical violations, low value
         If any of these are needed, Phase 14b can add PMD 7-compatible
         rewrites of the XPath expressions. -->
</ruleset>
