# =============================================================================
# Pantera Development Environment Variables
# =============================================================================

PANTERA_VERSION=2.0.7
PANTERA_UI_VERSION=2.0.7
PANTERA_USER_NAME=pantera
PANTERA_USER_PASS=changeme
PANTERA_CONFIG=/etc/pantera/pantera.yml

# JVM — lighter settings for local development
JVM_ARGS=-Xms512m -Xmx1g -XX:+UseG1GC -XX:+UseContainerSupport -Djava.io.tmpdir=/tmp/pantera -Dvertx.cacheDirBase=/tmp/pantera

# PostgreSQL
POSTGRES_USER=pantera
POSTGRES_PASSWORD=changeme

# Keycloak
KC_DB=postgres
KC_DB_URL=jdbc:postgresql://pantera-db:5432/keycloak
KC_DB_USERNAME=pantera
KC_DB_PASSWORD=changeme
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme
KC_HOSTNAME_STRICT=false
KC_HOSTNAME_STRICT_HTTPS=false
KC_HTTP_ENABLED=true

# Application secrets
JWT_SECRET=dev-jwt-secret-not-for-production
KEYCLOAK_CLIENT_SECRET=T4BphdGe7z8X5ycSe4aVjhDGdExx2yuJ

# Okta (disabled by default for local dev)
OKTA_ISSUER=https://placeholder.okta.com
OKTA_CLIENT_ID=placeholder
OKTA_CLIENT_SECRET=placeholder
OKTA_REDIRECT_URI=http://localhost:8081/okta/callback

# Elastic APM (disabled)
ELASTIC_APM_ENABLED=false
ELASTIC_APM_ENVIRONMENT=development
ELASTIC_APM_SERVER_URL=http://localhost:8200
ELASTIC_APM_SERVICE_NAME=pantera
ELASTIC_APM_SERVICE_VERSION=2.0.7
ELASTIC_APM_LOG_LEVEL=INFO
ELASTIC_APM_LOG_FORMAT_SOUT=JSON
ELASTIC_APM_TRANSACTION_MAX_SPANS=500
ELASTIC_APM_ENABLE_EXPERIMENTAL_INSTRUMENTATIONS=false
ELASTIC_APM_CAPTURE_BODY=off
ELASTIC_APM_USE_PATH_AS_TRANSACTION_NAME=false
ELASTIC_APM_SPAN_COMPRESSION_ENABLED=false
ELASTIC_APM_CAPTURE_JMX_METRICS=

# AWS (not needed for local dev with filesystem storage)
AWS_CONFIG_FILE=/dev/null
AWS_SHARED_CREDENTIALS_FILE=/dev/null
AWS_SDK_LOAD_CONFIG=0
AWS_PROFILE=default
AWS_REGION=eu-west-1

# Grafana (disabled in dev, but vars needed to suppress warnings)
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin
GF_USERS_ALLOW_SIGN_UP=false
GF_SERVER_ROOT_URL=http://localhost:3000
GF_INSTALL_PLUGINS=
