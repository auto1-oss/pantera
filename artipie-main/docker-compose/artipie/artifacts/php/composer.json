{
  "name": "ayd/sample-app",
  "description": "Sample PHP project using Composer with a private artifact repo",
  "type": "project",
  "require": {
    "php": ">=8.0",
    "doekos/shipkit": "^1.0.0",
    "ayd/helper-lib" : "^1.0.0",
    "wkda/notification-service": "^0.1.0",
    "symfony/polyfill-php85": "*",
    "doctrine/inflector": "*",
    "symfony/yaml": "^6.0"
  },
  "repositories": [
    {
      "type": "composer",
      "url": "http://localhost:8081/artifactory/api/composer/php_group"
    },
    {
      "packagist": false
    }
  ],
  "autoload": {
    "psr-4": {
      "App\\": "app/"
    }
  },
  "require-dev": {
    "symfony/web-profiler-bundle": "^7.3"
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "config": {
    "secure-http": false
  }
}
